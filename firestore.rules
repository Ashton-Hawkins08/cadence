rules_version = '2';

// Cadence Cloud data model: every user's backup lives entirely under
// /users/{uid}/... — one document per practice-tracking row, one collection
// per table (see lib/domain/services/cloud_sync_service.dart), plus a
// small profile map on the user document itself.
//
// A signed-in user may read and write ONLY their own subtree. There is no
// sharing, no admin access, and no cross-user visibility of any kind — this
// mirrors the app itself, where all data is single-user and local-first;
// the cloud is strictly a personal backup/sync layer.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
